# ─── Backend (Spring Boot) ─────────────────────────────────────────────
# Copia este archivo a .env (o exporta las variables) para correr en local.
# En produccion (Railway) se configuran como variables de entorno del servicio.

# Base de datos (dev: docker-compose Postgres; prod: Railway Postgres)
DB_URL=jdbc:postgresql://localhost:5433/sinapsistencia
DB_USER=sinapsistencia
DB_PASSWORD=sinapsistencia

# JWT (usa un secreto largo y aleatorio en base64 para produccion)
JWT_SECRET=change-me-in-prod-use-a-long-random-base64-secret-value-please
JWT_EXPIRATION=86400000

# Servicio ML (FastAPI) — dev local / URL de Railway en prod
ML_SERVICE_URL=http://localhost:8000

# n8n webhook (fire-and-forget para alertas de riesgo alto/critico)
N8N_WEBHOOK_URL=http://localhost:5678

# Cloudinary (storage de avatares + documentos de soporte)
# Formato: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# CORS: dominio del frontend (dev Angular / dominio de Vercel en prod)
CORS_ALLOWED_ORIGINS=http://localhost:4200
